# Database (MySQL)
DATABASE_URL=mysql://user:password@localhost:3306/multivohub_jobapp

# Clerk Auth (pk must match Clerk dashboard; backend needs CLERK_PUBLISHABLE_KEY for createClerkClient)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# OpenAI
OPENAI_API_KEY=sk-...

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# PayPal
PAYPAL_CLIENT_ID=...
PAYPAL_CLIENT_SECRET=...
PAYPAL_MODE=sandbox

# Telegram Bot
TELEGRAM_BOT_TOKEN=...

# Email / SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=...
SMTP_PASS=...

# Job APIs
REED_API_KEY=...
ADZUNA_APP_ID=...
ADZUNA_APP_KEY=...
JOOBLE_API_KEY=...

# Security
ENCRYPTION_KEY=your-32-char-encryption-key-here!

# Resend (email sending)
RESEND_API_KEY=re_...

# App
PORT=3001
NODE_ENV=production
# Production app origin (CORS + Clerk authorizedParties); use the canonical app host
FRONTEND_URL=https://jobs.multivohub.com
